def prepare_panel() -> pd.DataFrame:
    """
    Restrict to complete-case sample and make sure the index is monthly datetime.
    """
    panel = infl_panel.copy()
    panel.index = pd.to_datetime(panel.index)
    panel = panel.sort_index().dropna()
    return panel


def save_table(df: pd.DataFrame, name: str) -> None:
    csv_path = TAB_DIR / f"{name}.csv"
    xlsx_path = TAB_DIR / f"{name}.xlsx"
    df.to_csv(csv_path)
    df.to_excel(xlsx_path)


def rmse(y_true: pd.Series, y_pred: pd.Series) -> float:
    aligned = pd.concat([y_true.rename("actual"), y_pred.rename("pred")], axis=1).dropna()
    return float(np.sqrt(((aligned["pred"] - aligned["actual"]) ** 2).mean()))


def rmse_by_subperiod(actual: pd.Series, pred: pd.Series, periods: dict[str, tuple[str, str]]) -> pd.Series:
    out: dict[str, float] = {}
    for period_name, (start, end) in periods.items():
        out[period_name] = rmse(actual.loc[start:end], pred.loc[start:end])
    return pd.Series(out, name="RMSE")


def rank_table(avg_weights: pd.DataFrame) -> pd.DataFrame:
    """
    Rank countries within each subperiod (1 = largest average weight).
    """
    return avg_weights.rank(axis=0, ascending=False, method="min")


def dominant_country(weights: pd.DataFrame) -> pd.Series:
    """
    Return the country with highest weight at each date.
    Rows with all NaN stay NaN.
    """
    def _row_argmax(row: pd.Series):
        row = row.dropna()
        if row.empty:
            return np.nan
        return row.idxmax()

    return weights.apply(_row_argmax, axis=1)


def brief_nonzero_summary(weights: pd.DataFrame) -> pd.DataFrame:
    """
    Useful compact summary for A.1(c): how often each country receives non-zero weight.
    """
    is_nonzero = weights.fillna(0).gt(0)
    summary = pd.DataFrame({
        "non_zero_count": is_nonzero.sum(axis=0),
        "share_of_months": is_nonzero.mean(axis=0),
        "avg_weight_when_positive": weights.where(is_nonzero).mean(axis=0),
        "overall_avg_weight": weights.mean(axis=0),
    }).sort_values("overall_avg_weight", ascending=False)
    return summary


def plot_weights_over_time(weights: pd.DataFrame, title: str, filename: str) -> None:
    plt.figure(figsize=(14, 7))
    for col in weights.columns:
        plt.plot(weights.index, weights[col], label=col, linewidth=1)
    plt.title(title)
    plt.xlabel("Time")
    plt.ylabel("Pioneer weight")
    plt.legend(ncol=4, fontsize=8, frameon=False)
    plt.tight_layout()
    plt.savefig(FIG_DIR / filename, dpi=200, bbox_inches="tight")
    plt.close()


def plot_weights_heatmap(weights: pd.DataFrame, title: str, filename: str) -> None:
    plt.figure(figsize=(14, 6))
    plt.imshow(weights.T.fillna(0).values, aspect="auto", interpolation="nearest")
    plt.yticks(np.arange(len(weights.columns)), weights.columns)
    tick_idx = np.linspace(0, len(weights.index) - 1, 10, dtype=int)
    plt.xticks(tick_idx, [weights.index[i].strftime("%Y-%m") for i in tick_idx], rotation=45, ha="right")
    plt.colorbar(label="Pioneer weight")
    plt.title(title)
    plt.tight_layout()
    plt.savefig(FIG_DIR / filename, dpi=200, bbox_inches="tight")
    plt.close()


def compute_average_weights_by_period(weights: pd.DataFrame, periods: dict[str, tuple[str, str]]) -> pd.DataFrame:
    out = {}
    for period_name, (start, end) in periods.items():
        out[period_name] = weights.loc[start:end].mean(axis=0)
    return pd.DataFrame(out).sort_index()


def compute_methods_forecasts(
    eu_panel: pd.DataFrame,
) -> dict[str, pd.Series]:
    """
    Compute pooled estimates of Ukraine inflation using only EU countries as inputs.
    For all weight-based methods we build weights on eu_panel, then apply pooled_forecast.
    Median pooling directly returns a pooled series.
    """
    methods: dict[str, Callable[[pd.DataFrame], pd.DataFrame | pd.Series]] = {
        "PDM_Angles": compute_pioneer_weights_angles,
        "PDM_Distance": compute_pioneer_weights_distance,
        "Granger": compute_granger_weights,
        "Lagged_Correlation": compute_lagged_correlation_weights,
        "Multivariate_Regression": compute_multivariate_regression_weights,
        "Transfer_Entropy": compute_transfer_entropy_weights,
        "Linear_Pooling": compute_linear_pooling_weights,
        "Median_Pooling": compute_median_pooling,
    }

    forecasts: dict[str, pd.Series] = {}

    for name, fn in methods.items():
        result = fn(eu_panel)
        if isinstance(result, pd.Series):
            forecasts[name] = result.rename(name)
        else:
            forecasts[name] = pooled_forecast(eu_panel, result).rename(name)

    return forecasts


