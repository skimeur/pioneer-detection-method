def main() -> None:
    panel = prepare_panel()

    print("\nComplete-case sample")
    print(f"Start: {panel.index.min().date()}")
    print(f"End  : {panel.index.max().date()}")
    print(f"Shape: {panel.shape}")
    print(f"Columns: {list(panel.columns)}")

    part_a_results = run_part_a(panel)
    part_b_results = run_part_b(panel)

    print("\n" + "=" * 80)
    print("FILES WRITTEN")
    print("=" * 80)
    print(f"Output directory: {OUTPUT_DIR}")
    print(f"Figures         : {FIG_DIR}")
    print(f"Tables          : {TAB_DIR}")

    print("\nDone.")



# =========================
# PART A — INTERPRETATION
# =========================

# A.1(c) — Pioneer weights over time
# Pioneer weights are sparse and episodic rather than persistent.
# No country appears as a stable pioneer over the full sample.
# High weights occur in short bursts, suggesting temporary leadership
# rather than structural dominance.

# A.1(d) — Low inflation periods
# During low-inflation periods, strong pioneers are less frequent.
# This is consistent with the PDM logic: when inflation paths across countries
# are similar and dispersion is low, fewer clear directional leaders emerge.

# A.2(b) — Ranking across subperiods
# The ranking of pioneer countries changes across subperiods.
# This indicates that leadership in inflation dynamics is not stable over time
# and depends on the macroeconomic regime.

# A.2(c) — Economic interpretation
# Changes in ranking likely reflect structural shifts such as crises,
# monetary policy changes, or asymmetric shocks across countries.
# No single country consistently leads inflation dynamics across all periods.

# =========================
# PART B — INTERPRETATION
# =========================

# B.1(b) — Dominant pioneer
# The dominant pioneer changes over time, but Germany clearly dominates overall.
# It appears far more frequently than other countries, suggesting that
# Ukrainian inflation is most often preceded by German inflation movements
# in the rolling-window analysis.

# B.2(c) — Best method (full sample)
# PDM Distance achieves the lowest RMSE, closely followed by PDM Angles.
# However, differences across methods are small, so no method strongly dominates.

# B.2(c) — By subperiod
# The best-performing method varies across subperiods.
# PDM performs best in some periods, while Granger, Transfer Entropy,
# or Lagged Correlation outperform it in others.
# This suggests that model performance is regime-dependent.

# B.2(d) — Limitations
# This exercise should not be interpreted as true forecasting performance.
# PDM is designed to detect pioneers, not to optimize predictions.
# A low RMSE only indicates that the weighted combination of EU inflation
# tracks Ukrainian inflation reasonably well over the sample.
# It does not imply causal predictive power, especially in the presence
# of common shocks and structural breaks.
