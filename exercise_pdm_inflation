def run_part_a(panel: pd.DataFrame) -> dict[str, pd.DataFrame]:
    print("\n" + "=" * 80)
    print("PART A — WHO PIONEERED EUROPEAN INFLATION DYNAMICS?")
    print("=" * 80)

    # A.1(a)(b)
    w_angles = compute_pioneer_weights_angles(panel)

    # A.1(c) figure(s)
    plot_weights_over_time(
        w_angles,
        title="Part A.1 — PDM (angles) pioneer weights over time",
        filename="part_a1_pioneer_weights_lines.png",
    )
    plot_weights_heatmap(
        w_angles,
        title="Part A.1 — PDM (angles) pioneer weights heatmap",
        filename="part_a1_pioneer_weights_heatmap.png",
    )

    # A.1(c) compact summary table
    nonzero_summary = brief_nonzero_summary(w_angles)
    save_table(nonzero_summary, "part_a1_nonzero_summary")

    print("\nA.1 — Non-zero pioneer weight summary")
    print(nonzero_summary.round(4).to_string())

    # A.2(a)
    avg_by_period = compute_average_weights_by_period(w_angles, PERIODS)
    avg_by_period = avg_by_period.sort_values(by=list(avg_by_period.columns), ascending=False)
    save_table(avg_by_period, "part_a2_average_weights_by_period")

    print("\nA.2 — Average pioneer weights by subperiod")
    print(avg_by_period.round(4).to_string())

    # A.2(b)
    ranks = rank_table(avg_by_period)
    save_table(ranks, "part_a2_ranks_by_period")

    print("\nA.2 — Ranking by subperiod (1 = highest pioneer weight)")
    print(ranks.to_string())

    return {
        "w_angles": w_angles,
        "a1_nonzero_summary": nonzero_summary,
        "a2_avg_by_period": avg_by_period,
        "a2_ranks": ranks,
    }


# =============================================================================
# PART B — PREDICTING UKRAINE'S INFLATION TRAJECTORY
# =============================================================================

def rolling_dominant_pioneer_against_ua(
    panel: pd.DataFrame,
    eu_cols: list[str],
    target: str = "UA",
    window: int = 24,
) -> tuple[pd.DataFrame, pd.Series]:
    """
    Rolling pioneer detection relative to Ukraine.

    Interpretation used here:
    - For each EU country i, build a 2-column panel [i, UA] over a rolling window.
    - Compute PDM angles on that 2-series window.
    - At the last date of the window, keep the pioneer weight of country i.
    - Compare those EU-country weights across i and keep the dominant pioneer.

    This is the cleanest way to make 'relative to Ukraine' explicit.
    """
    dates = panel.index[window - 1 :]
    rel_weights = pd.DataFrame(index=dates, columns=eu_cols, dtype=float)

    for end_idx in range(window - 1, len(panel)):
        win = panel.iloc[end_idx - window + 1 : end_idx + 1]
        current_date = win.index[-1]

        for country in eu_cols:
            pair = win[[country, target]].dropna()
            if len(pair) < 3:
                rel_weights.loc[current_date, country] = np.nan
                continue

            pair_w = compute_pioneer_weights_angles(pair)

            if pair_w.empty:
                rel_weights.loc[current_date, country] = np.nan
            else:
                rel_weights.loc[current_date, country] = pair_w.iloc[-1][country]

    dominant = dominant_country(rel_weights)
    return rel_weights, dominant


def plot_dominant_pioneer(dominant: pd.Series, filename: str) -> None:
    cats = pd.Categorical(dominant, categories=[c for c in dominant.dropna().unique()], ordered=True)
    y = pd.Series(cats.codes, index=dominant.index).replace(-1, np.nan)

    plt.figure(figsize=(14, 5))
    plt.step(dominant.index, y, where="mid")
    plt.yticks(range(len(cats.categories)), cats.categories)
    plt.title("Part B.1 — Dominant EU pioneer relative to Ukraine (rolling window)")
    plt.xlabel("Time")
    plt.ylabel("Country")
    plt.tight_layout()
    plt.savefig(FIG_DIR / filename, dpi=200, bbox_inches="tight")
    plt.close()


def run_part_b(panel: pd.DataFrame) -> dict[str, pd.DataFrame | pd.Series]:
    print("\n" + "=" * 80)
    print("PART B — PREDICTING UKRAINE'S INFLATION TRAJECTORY")
    print("=" * 80)

    eu_panel = panel[EU_COUNTRIES].copy()
    actual_ua = panel[TARGET].copy()

    # B.1
    rel_weights, dominant = rolling_dominant_pioneer_against_ua(
        panel=panel,
        eu_cols=EU_COUNTRIES,
        target=TARGET,
        window=24,
    )
    save_table(rel_weights, "part_b1_rolling_relative_weights")
    dominant.to_frame(name="dominant_pioneer").to_csv(TAB_DIR / "part_b1_dominant_pioneer.csv")

    plot_dominant_pioneer(dominant, filename="part_b1_dominant_pioneer.png")

    dominant_counts = dominant.value_counts(dropna=True).rename("count").to_frame()
    save_table(dominant_counts, "part_b1_dominant_pioneer_counts")

    print("\nB.1 — Dominant pioneer counts")
    print(dominant_counts.to_string())

    # B.2
    forecasts = compute_methods_forecasts(eu_panel)

    rmse_full = {}
    rmse_periods = {}

    forecast_df = pd.DataFrame(index=panel.index)
    forecast_df["UA_actual"] = actual_ua

    for method_name, pred in forecasts.items():
        forecast_df[method_name] = pred
        rmse_full[method_name] = rmse(actual_ua, pred)
        rmse_periods[method_name] = rmse_by_subperiod(actual_ua, pred, PERIODS)

    save_table(forecast_df, "part_b2_forecasts_vs_actual")

    rmse_full_df = (
        pd.Series(rmse_full, name="RMSE_full_sample")
        .sort_values()
        .to_frame()
    )
    save_table(rmse_full_df, "part_b2_rmse_full_sample")

    rmse_by_period_df = pd.DataFrame(rmse_periods).T
    rmse_by_period_df["Full sample"] = pd.Series(rmse_full)
    rmse_by_period_df = rmse_by_period_df.sort_values("Full sample")
    save_table(rmse_by_period_df, "part_b2_rmse_by_method_and_period")

    print("\nB.2 — RMSE full sample")
    print(rmse_full_df.round(4).to_string())

    print("\nB.2 — RMSE by method and subperiod")
    print(rmse_by_period_df.round(4).to_string())

    return {
        "b1_relative_weights": rel_weights,
        "b1_dominant": dominant,
        "b1_dominant_counts": dominant_counts,
        "b2_forecasts": forecast_df,
        "b2_rmse_full": rmse_full_df,
        "b2_rmse_by_period": rmse_by_period_df,
    }


